* text=auto eol=lf

# Common binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.jar   binary
*.war   binary
*.class binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

# Markdown
*.md    text diff=markdown whitespace=-blank-at-eol
*.mdx   text diff=markdown whitespace=-blank-at-eol

# Python
*.py    text diff=python
*.pyi   text diff=python
*.pyw   text diff=python

# Generated Python binary files
*.pyc   binary
*.pyo   binary
*.pyd   binary

# HTML
*.html  text diff=html

# CSS
*.css   text diff=css
*.scss  text diff=css

# JavaScript
*.js    text

# JSON
*.json  text

# Test fixtures
*.hello text -eol
*.in    text -eol
*.out   text -eol
*.txt   text=auto -eol

# Vendored documentation assets
jekyll/assets/vendor/** linguist-vendored -text -eol
